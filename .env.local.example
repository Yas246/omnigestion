# Configuration Firebase
# Créez un projet sur https://console.firebase.google.com/
# Copiez les valeurs depuis Console > Project Settings > General > Your apps

NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Configuration Cloudinary
# Créez un compte sur https://cloudinary.com/
# Copiez les valeurs depuis Dashboard > Account Details

# Nom du cloud (visible dans le dashboard Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name

# Clé API Cloudinary (visible dans le dashboard Cloudinary)
CLOUDINARY_API_KEY=your_api_key

# Secret API Cloudinary (visible dans le dashboard Cloudinary)
# ⚠️ IMPORTANT: Gardez ce secret sécurisé et ne le commitez jamais dans Git !
CLOUDINARY_API_SECRET=your_api_secret

FIREBASE_SERVICE_ACCOUNT_KEY=
